#!/bin/sh

# Bygg om bat:s tema-cache så custom-teman (rose-pine) registreras.
# Utan detta faller bat tillbaka på default-temat på en ny maskin.
# run_onchange: kör om när temat ändras (hash nedan).
# theme-hash: {{ include "private_dot_config/bat/themes/rose-pine.tmTheme" | sha256sum }}

set -eu

if command -v bat >/dev/null 2>&1; then
  echo ">>> bat cache --build (registrerar custom-teman)"
  bat cache --build
fi
