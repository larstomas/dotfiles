#!/bin/bash

#- Error handling
# [set -e, -u, -o, -x pipefail explanation](https://gist.github.com/mohanpedala/1e2ff5661761d3abd0385e8223e16425?permalink_comment_id=3945021)
set -euf -o pipefail

#- Logging: tee all output to a shared log (also stays on the terminal)
chezmoi_log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi"
mkdir -p "$chezmoi_log_dir"
exec > >(tee -a "$chezmoi_log_dir/install.log") 2>&1
printf '\n===== %s  %s =====\n' "$(date '+%F %T')" "$(basename -- "$0")"

echo "#- Ask for admin password upfront"
sudo -v
# Keep-alive: update existing `sudo` time stamp until the script finishes
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

#- Functions
command_exists() {
  command -v "$1" >/dev/null 2>&1
}

echo "#- Update apt repos"
sudo apt-get update -y

#- Package lists live in .chezmoidata/packages.yaml.
#  Base = every Debian/Ubuntu machine; personal extras only on my own machines.
{{ $apt := .packages.linux.apt -}}
{{ if .personal -}}
{{   $apt = concat $apt .packages.linux.personal.apt -}}
{{ end -}}
echo "#- Install apt packages"
sudo apt-get install -y {{ $apt | sortAlpha | uniq | join " " }}

echo "#- Reload font cache"
fc-cache -fv

echo "#- Symlink batcat -> bat (apt installs bat as batcat)"
mkdir -p ~/.local/bin
ln -sf /usr/bin/batcat ~/.local/bin/bat

echo "#- Set login shell to zsh"
set_shell="zsh"
if [[ "${SHELL,,}" != *"$set_shell"* ]]; then
  if [[ "$(which $set_shell)" == *"brew"* ]]; then
    sudo chsh -s "/usr/bin/$set_shell" "$(whoami)"
    sudo chsh -s "/usr/bin/$set_shell" root
  else
    sudo chsh -s "$(which $set_shell)" "$(whoami)"
    sudo chsh -s "$(which $set_shell)" root
  fi
fi

echo "#- Install Homebrew"
if command_exists brew; then
  echo "# brew exists, skipping install"
else
  echo "# brew doesn't exist, continuing with install"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  touch "$HOME/.profile"
  echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"' >> "$HOME/.profile"
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

echo "#- Install Homebrew packages"
brew install {{ .packages.linux.brews | sortAlpha | uniq | join " " }}

{{ if .personal -}}
echo "#- Install snaps (GUI/desktop — personal machines only)"
sudo apt-get install -y snapd
sudo snap install core
{{ range .packages.linux.personal.snap -}}
sudo snap install {{ if .classic }}--classic {{ end }}{{ .name }}
{{ end -}}
{{ end -}}

echo "#- Install 1Password"
sudo apt-get install -y policykit-1  # Requirement: https://developer.1password.com/docs/cli/get-started/

# https://developer.1password.com/docs/cli/get-started/#install
curl -sS https://downloads.1password.com/linux/keys/1password.asc | sudo gpg --yes --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" | sudo tee /etc/apt/sources.list.d/1password.list >/dev/null
sudo mkdir -p /etc/debsig/policies/AC2D62742012EA22/
curl -sS https://downloads.1password.com/linux/debian/debsig/1password.pol | sudo tee /etc/debsig/policies/AC2D62742012EA22/1password.pol >/dev/null
sudo mkdir -p /usr/share/debsig/keyrings/AC2D62742012EA22
curl -sS https://downloads.1password.com/linux/keys/1password.asc | sudo gpg --yes --dearmor --output /usr/share/debsig/keyrings/AC2D62742012EA22/debsig.gpg
sudo apt-get update -y

echo "#-- Install 1Password Desktop"
sudo apt-get install -y 1password

echo "#-- Install 1Password CLI"
# https://developer.1password.com/docs/cli/about-biometric-unlock/
sudo apt-get install -y 1password-cli
# Biometric unlock needs setgid on the op binary — run AFTER install (apt puts op in /usr/bin/op)
sudo groupadd -f onepassword-cli
sudo chgrp onepassword-cli "$(command -v op)" && sudo chmod g+s "$(command -v op)"

echo "#-- Install 1Password GitHub plugin (gh)"
curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
sudo chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
sudo apt-get update -y
sudo apt-get install -y gh

echo "#-- Test 1Password installation"
op --version
# Login (idempotent: only add the account if op doesn't already know it)
if ! op account list 2>/dev/null | grep -q "backman.1password.com"; then
  op account add --address backman.1password.com --email {{ .email }}
fi
eval "$(op signin --account backman.1password.com)"
# Test read from 1Password (non-fatal)
op read "op://Personal/test_read_from_1password_vault/text" || echo ">>> WARNING: 1Password test-read failed (check the item exists)"

{{ if .personal -}}
echo "#-- Setup 1Password GitHub plugin (interactive — personal machines only)"
op plugin init gh
gh auth login
{{ end -}}
