#!/bin/bash

# Installera tmux plugin manager (tpm) + de plugins som deklareras i tmux.conf.
# Utan tpm laddas inga @plugin-rader (de gör tyst ingenting).
# run_onchange: kör om när tmux.conf ändras (hash nedan).
# tmux.conf-hash: {{ include "private_dot_config/tmux/tmux.conf" | sha256sum }}

set -eu

#- Logging: tee all output to a shared log (also stays on the terminal)
chezmoi_log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi"
mkdir -p "$chezmoi_log_dir"
exec > >(tee -a "$chezmoi_log_dir/install.log") 2>&1
printf '\n===== %s  %s =====\n' "$(date '+%F %T')" "$(basename -- "$0")"

# XDG-sökväg: tpm härleder plugin-pathen från ~/.config/tmux/tmux.conf → ~/.config/tmux/plugins/
TPM_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/tmux/plugins/tpm"

if command -v tmux >/dev/null 2>&1; then
  if [ ! -d "$TPM_DIR" ]; then
    echo ">>> Klonar tpm till $TPM_DIR"
    git clone --depth 1 https://github.com/tmux-plugins/tpm "$TPM_DIR"
  fi
  # Installera/uppdatera deklarerade plugins icke-interaktivt (best-effort; faila inte hela apply).
  echo ">>> tpm install_plugins"
  "$TPM_DIR/bin/install_plugins" || echo ">>> VARNING: tpm install_plugins misslyckades — kör prefix+I i tmux manuellt"
fi
