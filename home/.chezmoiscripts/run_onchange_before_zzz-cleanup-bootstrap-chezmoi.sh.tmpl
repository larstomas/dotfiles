#!/bin/bash

set -eu

#- Logging: tee all output to a shared log (also stays on the terminal)
chezmoi_log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi"
mkdir -p "$chezmoi_log_dir"
exec > >(tee -a "$chezmoi_log_dir/install.log") 2>&1
printf '\n===== %s  %s =====\n' "$(date '+%F %T')" "$(basename -- "$0")"

#- Remove the throwaway chezmoi used only for the initial bootstrap.
# The install command downloads chezmoi to ./bin and runs it; Homebrew then installs
# the permanent chezmoi during this apply. We remove both the currently-running
# throwaway (`.chezmoi.executable`) AND any leftover from a previous (possibly failed)
# bootstrap — get.chezmoi.io installs to ./bin, and scripts run with CWD=$HOME, so the
# common leftover is ~/bin/chezmoi. Only removes throwaways, never a permanent install.
exe="{{ .chezmoi.executable }}"

is_permanent() {
  case "$1" in
    */homebrew/bin/chezmoi | /usr/local/bin/chezmoi | /usr/bin/chezmoi \
      | "$HOME/.local/bin/chezmoi" | *linuxbrew/bin/chezmoi) return 0 ;;
    *) return 1 ;;
  esac
}

# A permanent chezmoi must exist before we remove any throwaway.
permanent=""
for p in /opt/homebrew/bin/chezmoi /usr/local/bin/chezmoi /usr/bin/chezmoi \
         "$HOME/.local/bin/chezmoi" /home/linuxbrew/.linuxbrew/bin/chezmoi \
         "$HOME/.linuxbrew/bin/chezmoi"; do
  [ -x "$p" ] && { permanent="$p"; break; }
done
if [ -z "$permanent" ]; then
  echo ">>> No permanent chezmoi found yet; leaving bootstrap binary in place."
  exit 0
fi

# Sweep the running binary + the common leftover location.
for candidate in "$exe" "$HOME/bin/chezmoi"; do
  if [ -x "$candidate" ] && ! is_permanent "$candidate"; then
    echo ">>> Removing throwaway bootstrap chezmoi: $candidate (permanent: $permanent)"
    rm -f "$candidate"
    rmdir "$(dirname "$candidate")" 2>/dev/null || true
  fi
done

# Remove ~/bin if it is now empty (e.g. the throwaway was already removed manually).
if [ -d "$HOME/bin" ] && rmdir "$HOME/bin" 2>/dev/null; then
  echo ">>> Removed empty ~/bin"
fi
