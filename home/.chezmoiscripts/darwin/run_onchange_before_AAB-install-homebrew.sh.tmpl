#!/bin/bash

#- Error handling
# [set -e, -u, -o, -x pipefail explanation](https://gist.github.com/mohanpedala/1e2ff5661761d3abd0385e8223e16425?permalink_comment_id=3945021)
set -euf -o pipefail

#- Logging: tee all output to a shared log (also stays on the terminal)
chezmoi_log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi"
mkdir -p "$chezmoi_log_dir"
exec > >(tee -a "$chezmoi_log_dir/install.log") 2>&1
printf '\n===== %s  %s =====\n' "$(date '+%F %T')" "$(basename -- "$0")"

echo "Running script has basename $( basename -- "$0"; ), dirname $( dirname -- "$0"; )";
echo "The present working directory is $( pwd; )";

#- Ask for admin password upfront
sudo -v
# Keep-alive: update existing `sudo` time stamp until the script finishes
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

#- Functions
command_exists() {
  command -v "$1" >/dev/null 2>&1
}

#- Install Homebrew
if command_exists brew; then
  echo "brew exists, skipping install"
else
  echo "brew doesn't exist, continuing with install"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [ "$(arch)" = "i386" ]; then
    echo "Setup Homebrew for x86"
    eval "$(/usr/local/bin/brew shellenv)"
  else
    echo "Setup Homebrew for ARM"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi
fi

export HOMEBREW_CASK_OPTS="--no-quarantine"

#- Tap(s)
brew tap 1password/tap

#- Package lists live in .chezmoidata/packages.yaml.
#  Base = every macOS machine; the personal extras are added only on my own
#  machines (.personal). A VM / ephemeral box gets just the base set.
{{ $brews := .packages.darwin.brews -}}
{{ $casks := .packages.darwin.casks -}}
{{ if .personal -}}
{{   $brews = concat $brews .packages.darwin.personal.brews -}}
{{   $casks = concat $casks .packages.darwin.personal.casks -}}
{{ end -}}

#- Install declaratively with a Brewfile generated from those lists (idempotent).
#  --no-upgrade: install what's missing, but don't upgrade already-installed
#  packages on every run (run `brew upgrade` separately on your own cadence).
brew bundle --no-upgrade --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF

{{ if .personal -}}
#- Mac App Store apps — personal machines only (needs App Store sign-in).
#  VMs aren't .personal, so they skip this entirely; on a real machine a single
#  failed app does not abort the bootstrap.
brew install mas
# `mas account` is unreliable on modern macOS, so just attempt each install.
# Already-installed = quick no-op; not signed in = non-fatal skip (logged).
{{ range .packages.darwin.personal.mas -}}
mas install {{ .id }} || echo ">>> mas {{ .id }} ({{ .name }}) hoppar över (ej inloggad i App Store?)"
{{ end -}}
{{ end -}}
