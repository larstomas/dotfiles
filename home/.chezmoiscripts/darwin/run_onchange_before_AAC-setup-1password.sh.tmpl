#!/bin/bash

#- Error handling
# [set -e, -u, -o, -x pipefail explanation](https://gist.github.com/mohanpedala/1e2ff5661761d3abd0385e8223e16425?permalink_comment_id=3945021)
# -e: exit on error
set -euf -o pipefail

#- Logging: tee all output to a shared log (also stays on the terminal)
chezmoi_log_dir="${XDG_STATE_HOME:-$HOME/.local/state}/chezmoi"
mkdir -p "$chezmoi_log_dir"
exec > >(tee -a "$chezmoi_log_dir/install.log") 2>&1
printf '\n===== %s  %s =====\n' "$(date '+%F %T')" "$(basename -- "$0")"

echo "Running script has basename $( basename -- "$0"; ), dirname $( dirname -- "$0"; )";
echo "The present working directory is $( pwd; )";

#- Ask for admin password upfront
sudo -v
# Keep-alive: update existing `sudo` time stamp until `.osx` has finished
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &


#- Ensure the 1Password CLI can AUTHENTICATE before the op:// templates are applied.
# Skip only if `op whoami` actually works — a merely-configured account is NOT enough:
# the desktop "Integrate with 1Password CLI" toggle is a GUI step that can't be
# scripted. Priming the session here (while you're present) stops the later template
# reads from timing out during unattended file application.
SUBDOMAIN="backman"
EMAIL="{{ .email }}"

if op whoami >/dev/null 2>&1; then
  echo ">>> 1Password CLI already signed in — skipping setup."
else
  # Add the account if op doesn't know it yet.
  if ! op account list 2>/dev/null | grep -q "$SUBDOMAIN.1password.com"; then
    op account add --address "$SUBDOMAIN.1password.com" --email "$EMAIL"
  fi
  open -a 1Password || true
  echo ">>> In 1Password: sign in, unlock, and enable"
  echo ">>>   Settings > Developer > 'Integrate with 1Password CLI'  (enable Touch ID unlock too)."
  read -r -p ">>> Press Enter once that is done... "
  if op whoami >/dev/null 2>&1; then
    echo ">>> 1Password CLI is working."
  else
    echo ">>> WARNING: 1Password CLI still can't authenticate — op:// templates will fail." >&2
    echo ">>>          Finish the CLI integration in 1Password, then re-run 'chezmoi apply'." >&2
  fi
fi

