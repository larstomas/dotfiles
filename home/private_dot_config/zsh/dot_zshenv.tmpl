HOMEBREW_PREFIX="$(brew --prefix)" # [ShellCheck: SC2155 – Declare and assign separately to avoid masking return values.](https://www.shellcheck.net/wiki/SC2155)
export HOMEBREW_PREFIX
HOMEBREW_CELLAR="$(brew --cellar)"
